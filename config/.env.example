# PHILIPS SENSEI Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ====================================
# AWS Configuration
# ====================================

# AWS Region for all services
AWS_REGION=us-east-1

# ====================================
# Frontend Configuration
# ====================================

# API Gateway endpoint for backend Lambda
VITE_API_BASE_URL=https://your-api-gateway-url/api

# Cognito Authentication
VITE_COGNITO_CLIENT_ID=your-cognito-client-id
VITE_COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback

# ====================================
# Backend Configuration (Lambda)
# ====================================

# Amazon Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# CloudWatch Logs
CLOUDWATCH_LOGS_REGION=us-east-1
CLOUDWATCH_LOGS_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/YourLogRole

# AWS X-Ray
XRAY_REGION=us-east-1

# DynamoDB
DYNAMODB_TABLE=sensei-sessions
DYNAMODB_REGION=us-east-1

# ====================================
# Application Settings
# ====================================

# Environment type: development, staging, production
ENVIRONMENT=development

# Session configuration
SESSION_TIMEOUT_MINUTES=30
MAX_MESSAGE_LENGTH=4000
MAX_ANALYSIS_TIME_SECONDS=300

# Feature flags
ENABLE_TRACE_LOGGING=false
ENABLE_DEBUG_MODE=false
